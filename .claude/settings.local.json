      "mcp__workbot__brain_get",
      "mcp__workbot__brain_write",
      "Bash(echo \"EXIT:$?\")",
      "Bash(npm --version)",
      "Bash(wsl -e bash -c *)",
      "Bash(wsl -u claude -e bash -c *)",
      "Bash(wsl -u claude -- bash -c *)",
      "mcp__workbot__agents_read",
      "mcp__workbot__subagent_list",
      "mcp__workbot__brain_list",
      "mcp__workbot__service_status",
      "mcp__workbot__brain_search",
      "mcp__workbot__brain_vsearch",
      "Skill(update-config)",
      "Skill(update-config:*)",
      "Bash(git add:*)",
      "Bash(git commit -m ':*)",
      "Bash(git push:*)",
      "Bash(gh auth:*)",
      "Read(//home/workbot/**)",
      "Bash(curl -s http://localhost:3001/api/health)",
      "Bash(echo \"EXIT: $?\")",
      "Bash(npm run:*)",
      "mcp__workbot__service_request",
      "Bash(curl -sk https://localhost:3001/api/health)",
      "Bash(curl -sk https://localhost:3001/api/services)",
      "Bash(curl -s http://localhost:3001/api/services)",
      "Bash(git rev-list:*)",
      "Bash(git bundle:*)",
      "Read(//tmp/**)",
      "Bash(git diff-tree:*)",
      "Bash(git ls-tree:*)",
      "Bash(git archive:*)",
      "Bash(npx tsc:*)",
      "Bash(npx tsx:*)",
      "Bash(claude mcp:*)",
      "mcp__workbot__git_credentials",
      "Bash(curl -ks https://localhost:5192/)",
      "Bash(ls /app/development/attendance-parsed-*.json)",
      "Bash(ls /app/development/sales-parsed-*.json)",
      "Bash(ls /app/development/.env*)",
      "Bash(ls /app/.env*)",
      "Bash(grep -oP 'ratings-list-item grid grid--flush.{0,3000}?ratings-list-item grid grid--flush' /app/development/classpass-reviews-full.html)",
      "Bash(ls /tmp/mb-debug-*)",
      "Bash(ls /app/development/data/mindbody-*/debug-*)",
      "Bash(ls /app/development/data/*/debug-*)",
      "mcp__workbot__workflow_create",
      "mcp__workbot__workflow_run",
      "mcp__workbot__workflow_status",
      "Bash(python3 -c \" import sys, json for line in sys.stdin: line = line.strip\\(\\) if not line: continue try: d = json.loads\\(line\\) if d.get\\('runId',''\\).startswith\\('31ea'\\): status = d.get\\('status','?'\\) nodes = d.get\\('nodeResults',{}\\) for nid, nr in nodes.items\\(\\): out = nr.get\\('output',''\\) if out: print\\(f'Node {nid}: status={nr.get\\(\\\\\"status\\\\\"\\)}, output tail: ...{out[-500:]}'\\) else: print\\(f'Node {nid}: status={nr.get\\(\\\\\"status\\\\\"\\)}'\\) except: pass \")",
      "Bash(npx qmd:*)",
      "Bash(curl -s http://localhost:3001/api/internal/store)",
      "Bash(curl -s http://localhost:3001/api/services/status)",
      "Bash(curl -s http://127.0.0.1:3001/api/services/status)",
      "Bash(netstat -tlnp)",
      "WebFetch(domain:help.developer.intuit.com)",
      "WebFetch(domain:docs.codat.io)",
      "Bash(curl -s http://localhost:3001/api/services/request -X POST -H \"Content-Type: application/json\" -d '{\"service\":\"quickbooks\",\"method\":\"GET\",\"url\":\"https://quickbooks.api.intuit.com/v3/company/9130351391597446/reports/TransactionList?account=Chase%20-%20Checking&transaction_type=Deposit&columns=tx_date,txn_type,is_cleared&start_date=2026-04-12&end_date=2026-04-12&minorversion=73\"}')",
      "Bash(curl -v http://localhost:3001/api/services/status)",
      "mcp__workbot__workflow_list",
      "Bash(python3 -c ':*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "workbot"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"SessionStart\",\"additionalContext\":\"BRAIN BOOT: You MUST read brain context/ACTIVE.md via brain_get BEFORE doing anything else. Also check AGENTS.md for new agent reports to assimilate. Do not skip this step.\"}}'",
            "statusMessage": "Loading brain context..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"Stop\",\"additionalContext\":\"BRAIN SAVE: Before ending, you MUST: 1) Update brain context/ACTIVE.md with current session state via brain_write. 2) Write any new reusable knowledge to the appropriate brain folder (decisions/, patterns/, corrections/, entities/, projects/). 3) Update AGENTS.md if active context changed. Do NOT skip this step.\"}}'",
            "statusMessage": "Saving brain context..."
          }
        ]
      }
    ]
  }
}
