{
  "name": "workbot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev -w server\" \"npm run dev -w client\"",
    "install:all": "npm install && npm install -w client && npm install -w server"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer": "^24.40.0"
  },
  "dependencies": {
    "croner": "^10.0.1",
    "dotenv": "^17.3.1",
    "highlight.js": "^11.11.1",
    "playwright": "^1.58.2",
    "react-force-graph-2d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "xlsx": "^0.18.5"
  }
}
